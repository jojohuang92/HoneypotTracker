# ── Database ──────────────────────────────────────────────
# SQLite database path (absolute recommended for production)
# DATABASE_URL=sqlite:////var/lib/honeypot/honeypot.db

# ── Cowrie ────────────────────────────────────────────────
# Path to the Cowrie JSON log file
# COWRIE_LOG_PATH=/var/log/cowrie/cowrie.json

# ── GeoIP ─────────────────────────────────────────────────
# Path to MaxMind GeoLite2-City database (.mmdb)
# Download from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# GEOIP_DB_PATH=/path/to/GeoLite2-City.mmdb

# ── API Keys ──────────────────────────────────────────────
# Admin key (secures /api/admin/* endpoints and SSE stream)
# ADMIN_API_KEY=your-secret-key-here

# VirusTotal API key (optional — enables malware file enrichment)
# VIRUSTOTAL_API_KEY=

# AbuseIPDB API key (optional — enables IP reputation scoring)
# ABUSEIPDB_API_KEY=

# ── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins (default: localhost dev ports)
# CORS_ORIGINS=https://dashboard.example.com,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────
# Format: "<count>/<period>" where period is second/minute/hour/day
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_STREAM=10/minute
